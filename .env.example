# ============================================================
# Configuration de l'environnement — copier en .env et adapter
# ============================================================

# --- Sécurité ---
JWT_SECRET=change-me-in-production

# --- Base de données : task-service ---
# Par défaut : SQLite (laisser tout commenté).
# Pour MySQL : décommenter les 5 lignes ci-dessous puis faire "make"
#
COMPOSE_PROFILES=mysql
MYSQL_HOST=mysql
MYSQL_USER=todo
MYSQL_PASSWORD=todopass
MYSQL_DB=todos

# --- Base de données : tout service ---
# Mettre à "true" pour forcer le mode mémoire (données perdues au redémarrage)
# USE_INMEMORY=false