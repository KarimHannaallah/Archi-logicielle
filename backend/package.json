{
  "name": "getting-started-app",
  "version": "1.0.0",
  "main": "src/index.ts",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "ts-node src/index.ts",
    "test": "jest --testPathPattern=spec/",
    "lint": "eslint src/ spec/",
    "lint:fix": "eslint src/ spec/ --fix",
    "lint:arch": "depcruise --config .dependency-cruiser.cjs src/",
    "prettify": "prettier -l --write \"**/*.{js,ts}\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.6.0",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.0",
    "wait-port": "^1.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "@types/uuid": "^9.0.0",
    "babel-jest": "^29.7.0",
    "dependency-cruiser": "^17.3.8",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.56.0"
  }
}