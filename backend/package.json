{
  "name": "todo-backend",
  "version": "1.0.0",
  "main": "src/index.ts",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "prettify": "prettier -l --write \"**/*.{js,ts}\"",
    "lint": "eslint src/ spec/",
    "lint:fix": "eslint src/ spec/ --fix",
    "lint:arch": "depcruise --config .dependency-cruiser.cjs src/",
    "start": "ts-node src/index.ts",
    "test": "jest --testPathPattern=spec/",
    "dev": "nodemon -L --exec ts-node src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^2.3.3",
    "sqlite3": "^5.1.2",
    "uuid": "^9.0.0",
    "wait-port": "^1.0.4"
  },
  "overrides": {
    "ansi-regex": "5.0.1"
  },
  "jest": {
    "transform": {
      "^.+\\.ts$": "ts-jest",
      "^.+\\.js$": "babel-jest"
    },
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ]
  },
  "prettier": {
    "trailingComma": "all",
    "tabWidth": 4,
    "useTabs": false,
    "semi": true,
    "singleQuote": true
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^25.2.3",
    "@types/uuid": "^10.0.0",
    "babel-jest": "^29.7.0",
    "dependency-cruiser": "^17.3.8",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.3.1",
    "nodemon": "^3.1.11",
    "prettier": "^2.7.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0"
  }
}
