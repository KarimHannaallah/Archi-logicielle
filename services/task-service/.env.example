# Persistence (sqlite par défaut, inmemory pour les tests, mysql si MYSQL_HOST défini)
USE_INMEMORY=false
SQLITE_DB_LOCATION=/data/task.db
# MYSQL_HOST=localhost
# MYSQL_USER=todo
# MYSQL_PASSWORD=todopass
# MYSQL_DB=todos

# Server
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=change-me-in-production

# Events
REDIS_HOST=localhost
REDIS_PORT=6379
